from crewai import Agent, Crew, Process, Task
from crewai.project import CrewBase, agent, crew, task
{% if imports %}
{% for import_module, names in imports.items() %}
from {{ import_module }} import {{ names | join(", ") }}
{% endfor %}
{% endif %}

@CrewBase
class {{ crew.name }}:
    """{{ crew.name }} — {{ agents | length }} agent(s), {{ tasks | length }} task(s)."""

    agents_config = "config/agents.yaml"
    tasks_config = "config/tasks.yaml"
{% for a in agents %}

    @agent
    def {{ a.name }}(self) -> Agent:
        return Agent(
            config=self.agents_config["{{ a.name }}"],
{% if a.tools %}
            tools=[{% for tool_name in a.tools %}{{ tool_constructors[tool_name] }}{% if not loop.last %}, {% endif %}{% endfor %}],
{% endif %}
            verbose={{ a.verbose | pytrue }},
        )
{% endfor %}
{% for tk in tasks %}

    @task
    def {{ tk.name }}(self) -> Task:
        return Task(
            config=self.tasks_config["{{ tk.name }}"],
{% if tk.tools %}
            tools=[{% for tool_name in tk.tools %}{{ tool_constructors[tool_name] }}{% if not loop.last %}, {% endif %}{% endfor %}],
{% endif %}
{% if tk.context %}
            context=[{% for c in tk.context %}self.{{ c }}(){% if not loop.last %}, {% endif %}{% endfor %}],
{% endif %}
        )
{% endfor %}

    @crew
    def crew(self) -> Crew:
        return Crew(
            agents=self.agents,
            tasks=self.tasks,
            process=Process.{{ crew.process }},
            verbose={{ crew.verbose | pytrue }},
            memory={{ crew.memory | pytrue }},
            cache={{ crew.cache | pytrue }},
{% if crew.process == "hierarchical" and crew.manager_llm %}
            manager_llm="{{ crew.manager_llm }}",
{% endif %}
        )


if __name__ == "__main__":
    result = {{ crew.name }}().crew().kickoff(inputs={})
    print(result)
